# ============================================================
# Options Analytics — Environment Variables
# Copy this file to .env for local development.
# On Railway, set these as Variables in the service dashboard.
# DO NOT commit .env — it is gitignored.
# ============================================================

# ── Provider ─────────────────────────────────────────────────
# Active data provider. Only "tradier" is production-ready.
DATA_PROVIDER=tradier

# ── Tradier (required) ────────────────────────────────────────
# Get your token from: https://dash.tradier.com/settings/api
TRADIER_TOKEN=your_tradier_api_token_here
# Set to false for live market data, true for sandbox testing
TRADIER_SANDBOX=false

# ── CORS (CRITICAL for production) ───────────────────────────
# Comma-separated list of allowed frontend origins.
# LOCAL DEV:  http://localhost:3000
# PRODUCTION: set to your actual frontend URL, e.g.:
#             https://your-app.netlify.app
# Leaving this as localhost in production will block all frontend requests.
CORS_ORIGINS=http://localhost:3000

# ── Cache ─────────────────────────────────────────────────────
# How long to cache option chain responses (seconds)
CACHE_TTL=120

# ── Rate limiting ─────────────────────────────────────────────
# Max API requests per minute per IP
RATE_LIMIT=30

# ── Robinhood (unused when DATA_PROVIDER=tradier) ─────────────
# Leave blank — not used in production
RH_USERNAME=
RH_PASSWORD=
RH_MFA_SECRET=
RH_PICKLE_B64=
